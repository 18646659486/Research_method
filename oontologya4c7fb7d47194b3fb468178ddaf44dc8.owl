##################################
# 关系定义
# 必须继承ex:custom_relation
# 有正向关系就需定义一个反向关系
# IRI命名规则：ex:{domain}_{relationLabel}_{range}
# 这样可以支持多组对象对使用相同的关系标签
##################################
ex:Equipment_hasBeltFault_BeltFault a owl:ObjectProperty ;
  rdfs:subPropertyOf ex:custom_relation ;
  rdfs:domain ex:Equipment ;
  rdfs:range ex:BeltFault ;
  rdfs:label "皮带机关联故障"@zh ;
  ex:relationLabel "hasBeltFault"@zh ;
  rdfs:comment "皮带机设备关联到其发生的故障"@zh .

ex:BeltFault_hasEquipment_Equipment a owl:ObjectProperty ;
  rdfs:subPropertyOf ex:custom_relation ;
  rdfs:domain ex:BeltFault ;
  rdfs:range ex:Equipment ;
  rdfs:label "故障关联设备"@zh ;
  ex:relationLabel "hasEquipment"@zh ;
  rdfs:comment "皮带机故障与发生故障的设备之间的关系"@zh .

ex:BeltFault_hasFaultSwitch_FaultSwitch a owl:ObjectProperty ;
  rdfs:subPropertyOf ex:custom_relation ;
  rdfs:domain ex:BeltFault ;
  rdfs:range ex:FaultSwitch ;
  rdfs:label "故障关联故障开关"@zh ;
  ex:relationLabel "hasFaultSwitch"@zh ;
  rdfs:comment "皮带机故障与相关故障开关的关联关系"@zh .

ex:FaultSwitch_hasBeltFault_BeltFault a owl:ObjectProperty ;
  rdfs:subPropertyOf ex:custom_relation ;
  rdfs:domain ex:FaultSwitch ;
  rdfs:range ex:BeltFault ;
  rdfs:label "皮带机关联故障"@zh ;
  ex:relationLabel "hasBeltFault"@zh ;
  rdfs:comment "皮带机设备关联到其发生的故障"@zh .

ex:BeltFault_hasMaintenanceRecord_MaintenanceRecord a owl:ObjectProperty ;
  rdfs:subPropertyOf ex:custom_relation ;
  rdfs:domain ex:BeltFault ;
  rdfs:range ex:MaintenanceRecord ;
  rdfs:label "故障关联保养记录"@zh ;
  ex:relationLabel "hasMaintenanceRecord"@zh ;
  rdfs:comment "故障与相关保养记录之间的关系"@zh .

ex:MaintenanceRecord_hasBeltFault_BeltFault a owl:ObjectProperty ;
  rdfs:subPropertyOf ex:custom_relation ;
  rdfs:domain ex:MaintenanceRecord ;
  rdfs:range ex:BeltFault ;
  rdfs:label "皮带机关联故障"@zh ;
  ex:relationLabel "hasBeltFault"@zh ;
  rdfs:comment "皮带机设备关联到其发生的故障"@zh .

ex:BeltFault_hasBeltScaleData_BeltScaleData a owl:ObjectProperty ;
  rdfs:subPropertyOf ex:custom_relation ;
  rdfs:domain ex:BeltFault ;
  rdfs:range ex:BeltScaleData ;
  rdfs:label "故障关联皮带秤数据"@zh ;
  ex:relationLabel "hasBeltScaleData"@zh ;
  rdfs:comment "皮带机故障关联相关的皮带秤数据"@zh .

ex:BeltScaleData_hasBeltFault_BeltFault a owl:ObjectProperty ;
  rdfs:subPropertyOf ex:custom_relation ;
  rdfs:domain ex:BeltScaleData ;
  rdfs:range ex:BeltFault ;
  rdfs:label "皮带机关联故障"@zh ;
  ex:relationLabel "hasBeltFault"@zh ;
  rdfs:comment "皮带机设备关联到其发生的故障"@zh .

ex:BeltFault_hasCoalType_CoalType a owl:ObjectProperty ;
  rdfs:subPropertyOf ex:custom_relation ;
  rdfs:domain ex:BeltFault ;
  rdfs:range ex:CoalType ;
